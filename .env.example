# Banco de dados
DATABASE_URL=postgresql://user:pass@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Provider ativo: "neon" (Better Auth) ou "google" (Auth.js)
AUTH_PROVIDER=neon

# Better Auth (provider=neon)
# Gerar com: openssl rand -hex 32
BETTER_AUTH_SECRET=string-aleatoria-minimo-32-chars

# Google OAuth — criar em console.cloud.google.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Auth.js (provider=google)
# Gerar com: openssl rand -hex 32
AUTH_SECRET=string-aleatoria-minimo-32-chars

# Token de autorização para o job de reavaliação automática
# Gerar com: openssl rand -hex 32
# Usado no header: Authorization: Bearer <valor>
CRON_SECRET=string-aleatoria-minimo-32-chars
